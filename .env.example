# ─── Required (모든 빌드) ──────────────────────────────────────────────
FIREBASE_PROJECT_ID=lettergo-147eb
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_STORAGE_BUCKET=lettergo-147eb.firebasestorage.app
STADIA_MAPS_API_KEY=your_stadia_maps_api_key
REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional: Email OTP providers (운영 권장 — 미설정 시 OTP 화면에 코드 노출) ─
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=otp@thiscount.io
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=otp@thiscount.io

# ─── Debug-only: 실 결제 테스트 ──────────────────────────────────────
# RC_REAL_PURCHASES_IN_DEBUG=true

# ─── Beta 전용 — 정식 launch 시 모두 제거 또는 주석 처리 ─────────────
#
# (1) BETA_FREE_PREMIUM=true
#     모든 사용자에게 Premium 무료 부여 (RevenueCat/StoreKit 우회).
#     정식 launch 시 반드시 false 또는 제거.
#
# (2) BETA_UPGRADE_SIMULATOR=true (default true)
#     Premium/Brand 구매 버튼 누르면 RevenueCat 호출 없이 즉시 활성화.
#     App Store Connect 상품 미등록 환경에서 동선 테스트 용도.
#     정식 launch 시 반드시 false 로 명시 또는 변수 제거.
BETA_UPGRADE_SIMULATOR=false
#
# (3) BETA_ADMIN_EMAIL=...
#     이 이메일에 한해 release 빌드에서도 admin/Brand 권한 자동 부여.
#     정식 launch 시 제거.
#
# (4) BETA_DISABLE_IN_RELEASE=true (default true)
#     release 빌드에서 모든 BETA_* 기능 강제 차단. 안전 가드.
#     정식 launch 시 그대로 true 유지 권장.
BETA_DISABLE_IN_RELEASE=true

# ─── 영구 어드민 (선택) ───────────────────────────────────────────────
# Build 272 (P0): hardcoded 제거 → dart-define 으로만 주입.
# 빈 값 또는 변수 제거 시 admin auto-bootstrap 비활성.
# 정식 launch 시 admin 패널이 필요하면 운영 이메일로 설정.
# PERMANENT_ADMIN_EMAIL=ceo@thiscount.io
