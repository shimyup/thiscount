# ─────────────────────────────────────────────────────────────────────
# Thiscount 정식 launch 용 .env.local 프리셋
# ─────────────────────────────────────────────────────────────────────
#
# 사용법:
#   1. .env.local 백업: cp .env.local .env.local.beta-backup
#   2. 이 파일을 .env.local 로 복사: cp docs/release/env.production.template .env.local
#   3. 아래 자리표시자를 실제 값으로 채움
#   4. ./scripts/release_preflight.sh 로 검증
#   5. IOS_BUILD_MODE=ipa ./scripts/build_ios_release.sh
#
# 변경점 vs 베타 .env.local:
#   ✗ BETA_FREE_PREMIUM 제거
#   ✗ BETA_ADMIN_EMAIL 제거 (또는 운영 admin 이메일)
#   ✓ BETA_UPGRADE_SIMULATOR=false (StoreKit 실 결제 활성)
#   ✓ BETA_DISABLE_IN_RELEASE=true (안전 가드)
#   ✓ PERMANENT_ADMIN_EMAIL 옵션 (운영 admin 이메일 또는 비움)
# ─────────────────────────────────────────────────────────────────────

# ─── Required ────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=lettergo-147eb
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_STORAGE_BUCKET=lettergo-147eb.firebasestorage.app
STADIA_MAPS_API_KEY=YOUR_STADIA_MAPS_API_KEY
REVENUECAT_IOS_KEY=appl_YOUR_RC_IOS_KEY
REVENUECAT_ANDROID_KEY=goog_YOUR_RC_ANDROID_KEY

# ─── Email OTP (필수, 운영) ─────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_KEY
RESEND_FROM_EMAIL=otp@thiscount.io
# (선택 fallback)
# SENDGRID_API_KEY=SG.YOUR_SENDGRID_KEY
# SENDGRID_FROM_EMAIL=otp@thiscount.io

# ─── Beta 차단 (정식 launch 핵심) ───────────────────────────────────
# 베타 무료 Premium 부여 OFF
# BETA_FREE_PREMIUM=true   ← 제거 (default false)
#
# 베타 업그레이드 시뮬레이터 OFF — 실제 StoreKit 결제로 전환
BETA_UPGRADE_SIMULATOR=false
#
# 베타 admin email OFF
# BETA_ADMIN_EMAIL=...     ← 제거
#
# release 빌드에서 BETA_* 모두 강제 차단 (안전 가드)
BETA_DISABLE_IN_RELEASE=true

# ─── 영구 어드민 (선택) ─────────────────────────────────────────────
# 운영 admin 패널 필요 시 이 이메일에 한해 admin 권한 부여.
# 미설정 시 admin auto-bootstrap 비활성 (정식 launch 권장).
# PERMANENT_ADMIN_EMAIL=ceo@thiscount.io

# ─── Apple Connect API Key (빌드 export 용) ─────────────────────────
# 빌드 스크립트가 ASC API Key 로 자동 provisioning + export 시도.
# 미설정 시 manual signing fallback (현재 사용 흐름).
# ASC_API_KEY_ID=PPC3B3JS5V
# ASC_API_KEY_PATH=$HOME/private_keys/AuthKey_PPC3B3JS5V.p8
# ASC_API_ISSUER_ID=1cfdd647-e5d9-4f98-bcd6-fff8299f80ec
