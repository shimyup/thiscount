rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 배경 ─────────────────────────────────────────────────────────────
    // Letter Go 는 자체 OTP 인증(이메일/SMS) + Firestore 용 anonymous Firebase
    // Auth 를 사용한다. 그래서 `request.auth.uid` 가 매번 바뀌는 1회용
    // 식별자라서 Firestore rule 로 owner-only check 가 직접적으로 작동하지
    // 않는다. (향후 Phone/Email Auth 마이그레이션 시 uid 기반으로 강화 가능.)
    //
    // 보안 모델 (Build 207 강화):
    //   - read/list 는 지도 동기화·편지 픽업을 위해 누구나 허용.
    //   - create 는 isSignedIn() + 핵심 필드 검증 (익명 편지 enforcement,
    //     content 크기 한도, 필드 화이트리스트).
    //   - update 는 시스템 카운터 / 도착 상태 필드만 변경 허용. 본문·발신자
    //     ID·이름·발송시각은 변경 불가.
    //   - delete 는 모두 차단. 실제 삭제는 관리자 API key REST 만 가능.
    //   - reports 는 create 만, 읽기·수정·삭제 차단 (관리자 REST 전용).
    //
    // 클라이언트는 letter 본문이 공개 데이터인 줄 알고 사용해야 한다 — 즉,
    // 본문에는 사용자가 의도적으로 공유하기로 한 텍스트만 들어간다. 이미지·
    // 쿠폰 코드도 마찬가지. 민감 PII(전화번호·이메일)는 letter 본문에
    // 저장되지 않는다 (compose 화면이 검증).

    function isSignedIn() {
      return request.auth != null;
    }

    // 익명 편지가 정말 익명인지 검증.
    //   senderId  → "anon_" prefix (per-letter unique, 역추적 불가)
    //   senderName → 고정 sentinel '__anonymous__' (UI 가 i18n 으로 치환)
    function isAnonLetterValid(data) {
      return data.isAnonymous == false
          || (data.senderName == '__anonymous__'
              && data.senderId is string
              && data.senderId.matches('^anon_.+'));
    }

    // 편지 생성 시 검증 — 본문 크기 + 익명 enforcement.
    function isValidLetterCreate(data) {
      return data.content is string
          && data.content.size() <= 5000
          && data.senderId is string
          && data.senderName is string
          && data.senderName.size() <= 100
          && data.isAnonymous is bool
          && isAnonLetterValid(data);
    }

    // update 로 변경 가능한 필드 화이트리스트 — 카운터 + 도착 상태만.
    // 본문 / 발신자 / 좌표 / 카테고리 / 쿠폰 정보는 create 후 immutable.
    function isAllowedLetterUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'pickupCount', 'redeemedCount', 'readCount', 'likeCount',
            'ratingTotal', 'ratingCount',
            'status', 'arrivedAt', 'readAt', 'isReadByRecipient',
            'reportCount',
          ]);
    }

    // ── users 컬렉션 ──────────────────────────────────────────────────
    match /users/{userId} {
      // ⚠️ TODO(security/post-207): 이상적으로는 read/list 를 isMapPublic=true
      // 또는 owner 로 한정하고 싶지만, 현재 클라이언트가 REST `:list` 엔드
      // 포인트로 사용자를 가져오기 때문에 (`syncWorldUsersFromServer`
      // app_state.dart:4666) where 필터가 적용되지 않아 strict read 룰이면
      // 전체 list 가 거부된다. 다음 빌드에서 `:runQuery` + structured query
      // (`where('isMapPublic','==',true)`) 로 마이그레이션 후 룰 강화 예정.
      //
      // 현 상태의 PII 보호 layer:
      //   - 클라이언트가 `mask.fieldPaths=...` 로 공개 필드만 요청
      //     (latitude/longitude/countryFlag/username/카운터 — phone/email 제외)
      //   - latitude/longitude 는 ~110m 정밀도로 round 후 저장
      //   - 클라이언트 코드가 `isMapPublic=false` 인 사용자를 즉시 skip
      allow read: if true;
      allow list: if true;

      // 익명 인증 환경 — owner check 강제 불가. 베타 기간 isSignedIn() 만 요구.
      allow create, update: if isSignedIn();

      // 회원 탈퇴는 클라이언트가 직접 호출. owner check 불가하지만 1회 호출
      // 후 prefs 가 비워지고 secure storage 도 wipe 되므로 abuse 표면 작음.
      allow delete: if isSignedIn();
    }

    // ── letters 컬렉션 ────────────────────────────────────────────────
    match /letters/{letterId} {
      // map 동기화·픽업을 위해 누구나 read/list. (본문은 사용자가 공개를
      // 전제로 작성한다는 정책.)
      allow read: if true;
      allow list: if true;

      // create 시 본문 크기·익명 enforcement 검증.
      allow create: if isSignedIn() && isValidLetterCreate(request.resource.data);

      // update 는 카운터·상태 필드만. 본문/발신자/좌표/카테고리는 immutable.
      allow update: if isSignedIn() && isAllowedLetterUpdate();

      // delete 차단 — admin REST 만 가능.
      allow delete: if false;
    }

    // ── reports 컬렉션 (편지 신고 기록) ─────────────────────────────────
    match /reports/{reportId} {
      // 인증된 사용자는 신고 생성 가능. 읽기·수정·삭제는 관리자 REST 만.
      allow create: if isSignedIn();
      allow read, list, update, delete: if false;
    }

    // ── brand_zones 컬렉션 (Build 283 — Brand auto-drop) ───────────────
    // Brand 사용자가 미리 설정한 "쿠폰 zone": 좌표 + 반경 + 쿠폰 내용. 일반
    // 사용자가 zone 반경 안에 들어오면 자동으로 letter 1통이 인박스에 도착.
    //
    // 보안 모델 (anonymous Firebase Auth 한계):
    //   - read/list 는 누구나 — 클라이언트가 가까운 zone 쿼리해야 함. 본문
    //     은 brand 가 의도적으로 공개하는 쿠폰 정보 (PII 없음).
    //   - create 는 isSignedIn() + 본문 크기 + brandId 비어있지 않음.
    //     실제 brand verified 검증은 client-side + Phase 2 의 Cloud Function
    //     server-side re-verify 로 강화 예정 (anonymous auth 이므로 본 rule
    //     에서 직접 owner-check 불가).
    //   - update 는 redeemedCount 만 (counter increment) — 본문/좌표/반경/
    //     시간은 immutable.
    //   - delete 차단 — admin REST + 만료된 zone 일괄 정리 (별도 cron 또는
    //     Cloud Function).

    function isValidBrandZoneCreate(data) {
      return data.brandId is string && data.brandId.size() > 0
          && data.brandName is string && data.brandName.size() <= 100
          && data.content is string && data.content.size() <= 1000
          && data.radiusM is number
          && data.radiusM >= 50.0 && data.radiusM <= 5000.0
          && data.startsAt is string
          && data.expiresAt is string
          && data.maxRedeems is number
          && data.maxRedeems >= 0 && data.maxRedeems <= 100000;
    }

    function isAllowedBrandZoneUpdate() {
      // redeemedCount 만 변경 가능. counter increment 흐름.
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['redeemedCount']);
    }

    match /brand_zones/{zoneId} {
      allow read, list: if true;
      allow create: if isSignedIn() && isValidBrandZoneCreate(request.resource.data);
      allow update: if isSignedIn() && isAllowedBrandZoneUpdate();
      allow delete: if false;
    }

    // ── 기타 경로는 모두 차단 ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
