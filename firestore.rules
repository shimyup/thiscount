rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 배경 ─────────────────────────────────────────────────────────────
    // Letter Go 는 자체 OTP 인증(이메일) + Firestore 용 anonymous Firebase
    // Auth 를 사용한다. 따라서 `request.auth.uid` 는 매번 바뀌는 anonymous
    // 식별자라 관리자 UID 화이트리스트가 고정 작동하지 않는다.
    //
    // 관리자 판별·접근은 다음 두 층에서 처리된다:
    //   1) 앱(UI) 내부: `BetaConstants.isAdmin(email)` 로 관리자 메뉴 노출
    //      (현재 관리자 이메일: ceo@airony.xyz)
    //   2) 데이터 접근: `adminFetchAllUsers/Letters` 가 API key 기반 REST
    //      리스트 엔드포인트로 Firestore 규칙 평가를 우회
    //
    // 따라서 이 규칙의 역할은 일반 사용자 데이터의 기본 보호에만 한정한다.
    // 즉, 누구나 자기 자신 문서만 쓸 수 있고, 공개 문서는 모두 읽을 수 있다.

    function isSignedIn() {
      return request.auth != null;
    }

    // ── users 컬렉션 ──────────────────────────────────────────────────
    match /users/{userId} {
      // 지도·탐색용으로 공개. isMapPublic=false 인 사용자의 세부 정보는
      // 클라이언트에서 필드 레벨로 필터링한다.
      allow read: if true;
      allow list: if true;

      // 인증된 사용자만 자기 문서 쓰기. (anonymous UID 가 여러 번 바뀌면
      // 이전 문서 접근 불가한 한계 있음. 이 앱은 OTP 인증 이후 서버 측에서
      // 기존 user document 를 덮어쓰기 패턴이라 이 규칙으로 충분.)
      allow write: if isSignedIn();
    }

    // ── letters 컬렉션 ────────────────────────────────────────────────
    match /letters/{letterId} {
      // 수신 동기화 + 지도 궤적 표시를 위해 모두에게 읽기·리스트 허용
      allow read: if true;
      allow list: if true;

      // 인증된 사용자만 편지 생성 / 상태 변경 / 삭제 가능
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── reports 컬렉션 (편지 신고 기록) ─────────────────────────────────
    match /reports/{reportId} {
      // 인증된 사용자는 신고 생성 가능. 읽기·수정·삭제는 금지 (앱 관리자
      // 기능은 API key REST 로 접근하므로 이 규칙과 무관).
      allow create: if isSignedIn();
      allow read, list, update, delete: if false;
    }

    // ── 기타 경로는 모두 차단 ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
