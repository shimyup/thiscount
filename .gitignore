# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Sensitive keys and local service config
*.p8
AuthKey_*.p8
SubscriptionKey_*.p8
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Local environment files
.env.local
.env.*.local
.secrets/

# Large local data artifacts under scripts/
scripts/*.txt
scripts/*.zip
!scripts/*.py
!scripts/*.sh

# Local screenshot captures (keep only curated ready assets in git)
docs/marketing/screenshots/raw/
